# ─── WhatsApp Cloud API ───────────────────────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_API_TOKEN=your_whatsapp_api_token
WHATSAPP_VERIFY_TOKEN=your_custom_verify_token
WHATSAPP_APP_SECRET=your_app_secret_for_signature_verification

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ─── Google (Service Account — for Calendar only) ─────────────────────────────
# Path to the downloaded service account JSON key file
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=./google-service-account.json
GOOGLE_CALENDAR_ID=your_calendar_id@group.calendar.google.com

# ─── Gmail (OAuth2 — requires refresh token) ──────────────────────────────────
GMAIL_CLIENT_ID=your_gmail_oauth_client_id
GMAIL_CLIENT_SECRET=your_gmail_oauth_client_secret
GMAIL_REFRESH_TOKEN=your_gmail_refresh_token
GMAIL_SENDER=clinic@example.com

# ─── Business Logic ───────────────────────────────────────────────────────────
TIMEZONE=Asia/Beirut
APPOINTMENT_DURATION_MIN=30
OFFICE_HOURS_AM_START=09:00
OFFICE_HOURS_AM_END=12:00
OFFICE_HOURS_PM_START=13:00
OFFICE_HOURS_PM_END=17:00
MIN_BOOKING_LEAD_HOURS=24
SLOTS_TO_OFFER=5

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
